# .ralphrc - Ralph project configuration

# Project identification
PROJECT_NAME="flora-autonomous-garden"
PROJECT_TYPE="generic"

# Claude Code CLI command
CLAUDE_CODE_CMD="claude"

# Loop settings
MAX_CALLS_PER_HOUR=100
CLAUDE_TIMEOUT_MINUTES=15
CLAUDE_OUTPUT_FORMAT="json"

# Tool permissions
ALLOWED_TOOLS="Write,Read,Edit,Glob,Grep,Skill,Bash(git add *),Bash(git commit *),Bash(git diff *),Bash(git log *),Bash(git status),Bash(git status *),Bash(git push *),Bash(git pull *),Bash(git fetch *),Bash(git checkout *),Bash(git branch *),Bash(git stash *),Bash(git merge *),Bash(git tag *),Bash(git remote *),Bash(git config *),Bash(npm *),Bash(pytest),Bash(pytest *),Bash(pip *),Bash(pip3 *),Bash(python *),Bash(python3 *),Bash(sed *),Bash(cat *),Bash(gh *),Bash(mkdir *),Bash(cp *),Bash(mv *),Bash(touch *),Bash(ls *),Bash(find *),Bash(which *),Bash(echo *),Bash(curl *),Bash(chmod *),Bash(env *),Bash(apt-cache *),Bash(dpkg *),Bash(snap *),Bash(tee *),Bash(sort *),Bash(head *),Bash(tail *),Bash(wc *),Bash(grep *),Bash(xargs *),Bash(test *),Bash(printf *)"

# Session management
SESSION_CONTINUITY=true
SESSION_EXPIRY_HOURS=24

# Task sources — Ralph polls GitHub Issues labelled 'ralph-task'
TASK_SOURCES="github"
GITHUB_TASK_LABEL="ralph-task"
BEADS_FILTER="status:open"

# Circuit breaker thresholds
CB_NO_PROGRESS_THRESHOLD=3
CB_SAME_ERROR_THRESHOLD=5
CB_OUTPUT_DECLINE_THRESHOLD=70
